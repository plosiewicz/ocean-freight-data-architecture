# Ocean Freight Forwarder Data Architecture (MSDS 683) — environment template.
#
# Copy this file to `.env` and fill in real values. The real `.env` is GITIGNORED
# (see .gitignore: *.env*) and MUST NEVER be committed (threat T-03-01).
#
# A7: The UN Comtrade KEYLESS public preview is sufficient for this project's bounded
# trade-flow pull. COMTRADE_API_KEY is optional — leave it blank to use the keyless
# preview tier. Only set it if you need higher rate limits.
COMTRADE_API_KEY=

# GCP auth (Python side) is via Application Default Credentials (ADC) — no key file
# needed. Confirm ADC is present: ~/.config/gcloud/application_default_credentials.json
# authed to project data-architecture-msds683.

# --- Phase 11: live BigQuery seam — Node/Vercel inline credentials (D-01..D-06) ---
# Server-only, UN-PREFIXED placeholders consumed by web/lib/bigquery.ts (Node runtime).
# NEVER NEXT_PUBLIC_-prefix these (would inline a secret into the client bundle and trip
# the secret-gate, threat T-11-01). Fill real values ONLY in Vercel Project Settings →
# Environment Variables, never in committed git. Absent ⇒ handlers serve golden (D-06).
#
# GCP_SA_KEY_B64: base64 of the FULL service-account-key JSON (D-01 — base64 round-trip
# preserves the private_key newlines, avoiding the \n-escaping footgun). Required for live.
GCP_SA_KEY_B64=<base64-encoded-service-account-json>
# BQ_PROJECT: optional. Defaults to data-architecture-msds683 (D-02). Override only if the
# live BigQuery project changes.
BQ_PROJECT=data-architecture-msds683
# LIVE_QUERY_TIMEOUT_MS: optional. Defaults to 7000 (D-03). Widen toward ~9000 only if the
# Vercel tier moves to Pro/Fluid (D-04).
LIVE_QUERY_TIMEOUT_MS=7000

# --- Phase 6: managed ArangoDB cloud cluster (D-01) -------------------------
# Placeholders only — fill these in the gitignored real `.env` (NEVER committed,
# threat T-06-01). lib/arango_client.py reads ONLY these names (prior-repo pattern,
# RESEARCH Pitfall 2 — NOT the D-02 ARANGO_ENDPOINT/USER/DB parenthetical). TLS is
# always on; ARANGO_URL must be the HTTPS connection endpoint from the cluster
# dashboard. ARANGO_GRAPH is the named graph (ocean_network).
ARANGO_URL=
ARANGO_USERNAME=
ARANGO_PASSWORD=
ARANGO_DATABASE=
ARANGO_GRAPH=ocean_network
