.planning/
.claude/
.DS_Store

# Bulk sample data — proof-of-pull artifacts, never committed (respect source terms)
samples/

# Bulk pipeline data — AIS cache + synthetic JSONL; only synthetic.sha256 is committed
# (the determinism manifest lands in a later plan). Threat T-03-01.
data/

# Local credentials / config — no committed secrets (DEL-02 precedent, threats T-02-01 / T-03-01)
.env
.env.*
*.env*
*.key
secrets.*
# ...but DO commit the non-secret template (placeholder values only)
!.env.template

# Python build / runtime artifacts
__pycache__/
*.pyc
.venv/

# Local Airflow runtime home — metadata DB + logs created by `make load-bq`
# (`airflow dags test`). Never committed; regenerated on demand via `airflow db migrate`.
.airflow/

# Per-run criticality sidecar (gral|networkx path marker) — runtime, regenerated.
analytics/.criticality_run_meta.json
# ...but DO commit the credential-free frozen golden (counts/floats/strings only,
# T-06-08 — the Phase-7 demo-safety artifact must be committable).
!criticality.golden.json
